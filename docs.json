{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Alvys API",
  "description": "Unlock the full potential of your logistics operations with the Alvys API.",
  "colors": {
    "primary": "#434FEF",
    "light": "#6366F1",
    "dark": "#3730A3"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "openapi": "openapi/alvys.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "autogenerate": true,
      "languages": ["curl", "python", "javascript", "go"]
    },
    "mdx": {
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "docs/getting-started",
              "docs/authentication",
              "docs/versioning",
              "docs/base-url"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi/alvys.json"
      },
      {
        "tab": "AI & Agents",
        "groups": [
          {
            "group": "Model Context Protocol",
            "pages": [
              "ai-agents/mcp",
              "ai-agents/available-mcp-tools"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": ["changelog/index"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@alvys.com"
      },
      {
        "label": "Contact",
        "href": "https://alvys.com/resources/contact"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/alvysio",
      "linkedin": "https://linkedin.com/company/alvys"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "download-spec",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
